# Root app server
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000
DISABLE_HMR=false
NODE_ENV=development
SERVICE_NAME=edumaster-platform
ENVIRONMENT_LABEL=local
JITSI_MEET_DOMAIN=meet.jit.si
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_ROOM_PREFIX=edumaster-live
TRUST_PROXY=true
LOG_LEVEL=info
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
CORS_ORIGIN=*

# Payments
STRIPE_SECRET_KEY=sk_test_replace_me
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# AI Studio / Gemini
GEMINI_API_KEY=replace_me

# YouTube upload automation
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
YOUTUBE_UPLOAD_REFRESH_TOKEN=replace_me
PRIVATE_VIDEO_TOKEN_SECRET=replace_with_a_long_random_secret
PRIVATE_VIDEO_TOKEN_TTL_SECONDS=900
PRIVATE_VIDEO_DELIVERY_URL_TTL_SECONDS=900
PRIVATE_VIDEO_DRM_ENABLED=false
PRIVATE_VIDEO_STORAGE_PROVIDER=local
ENABLE_VIDEO_TRANSCODING=true
SOURCE_PLAYBACK_FALLBACK_ENABLED=true
VIDEO_DELIVERY_PROFILE=cost-saver-hls
VIDEO_TARGET_RENDITIONS=480p,720p
VIDEO_HLS_SEGMENT_DURATION_SECONDS=6
VIDEO_KEEP_SOURCE_AFTER_PROCESSING=false
MAX_VIDEO_UPLOAD_MB=2048
VITE_MAX_VIDEO_UPLOAD_MB=2048

# Backend API / auth
MONGODB_URI=mongodb://127.0.0.1:27017/edumaster
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/edumaster
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace_with_a_long_random_secret
S3_BUCKET=replace_me
S3_REGION=ap-south-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Notes
# 1. The root dev server mounts the backend at /backend/api.
# 2. If MongoDB is not configured, the backend starts in memory mode with sample demo data.
# 3. Postgres and Redis are optional in the current repo but are exposed through health/config for production wiring.
# 4. Demo credentials in memory mode:
#    admin@edumaster.local / Admin@123
#    student@edumaster.local / Student@123
